# ==========================================
# V2V Environment Variables (template)
# Copy to .env.local and fill in values.
# ==========================================

# Supabase (Demilade — ledger persistence)
SUPABASE_URL=                          # Project URL (server-side; required for API routes)
SUPABASE_SERVICE_ROLE_KEY=             # Server only — never import into client components
SUPABASE_ANON_KEY=                     # Public anon key (optional client reads)
NEXT_PUBLIC_SUPABASE_URL=              # Legacy alias if frontend already uses it
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Paystack (Demilade — checkout + webhooks)
PAYSTACK_SECRET_KEY=                 # sk_test_… server-only Bearer token
PAYSTACK_PUBLIC_KEY=                 # pk_test_… client-side checkout key
PAYSTACK_CHECKOUT_EMAIL_DOMAIN=      # Optional; default checkout.v2vprotocol.com (Paystack rejects .local)

# App
APP_BASE_URL=http://localhost:3000   # Paystack callback_url base
DEFAULT_MERCHANT_ID=                 # Optional; falls back to default_merchant

# AethexAI STT — https://developers.aethexai.com
AETHEX_API=                           # Vercel name used by some teammates
AETHEX_API_KEY=                       # Preferred name
AETHANA_API_KEY=                      # Legacy alias (same key)

# OpenAI — Whisper fallback + LLM (Precious)
OPENAI_API_KEY=

# Groq - Fast LLM Parsing
GROQ_API_KEY=

# YarnGPT TTS (Precious)
YARNGPT_API_KEY=

# Voice orchestration (Demilade — Day 4; Precious swaps in real ML)
INTENT_PARSER_MODE=stub                 # stub | ml
ML_INTENT_PARSER_URL=                   # POST { transcript } -> ParsedIntent JSON
NEGOTIATION_AGENT_MODE=stub             # stub | ml
ML_NEGOTIATION_AGENT_URL=               # POST { session, userTurn } -> agent response
