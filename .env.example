# ==========================================
# V2V Environment Variables (template)
# Copy to .env.local and fill in values.
# ==========================================

# Supabase (Demilade — ledger persistence)
# Project URL from Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=                   # Public anon key (client-safe, future use)
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=       # Server-only — never import into client components

# Paystack (Demilade — checkout + webhooks)
PAYSTACK_SECRET_KEY=                 # sk_test_… server-only Bearer token
PAYSTACK_PUBLIC_KEY=                 # pk_test_… client-side checkout key

# App
APP_BASE_URL=http://localhost:3000   # Paystack callback_url base
DEFAULT_MERCHANT_ID=                 # Optional; falls back to default_merchant

# Aethana AI STT (Precious)
AETHANA_API_KEY=

# OpenAI — Whisper fallback + LLM (Precious)
OPENAI_API_KEY=

# YarnGPT TTS (Precious)
YARNGPT_API_KEY=
